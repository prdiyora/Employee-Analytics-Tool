# Copy this file to .env and fill values for local development.
# Do NOT commit your real DATABASE_URL to source control.

# Example PostgreSQL connection string (replace with your own):
# DATABASE_URL=postgresql://username:password@host:port/database

# For Render deployment, set the following environment variable in the Render service
# (do not commit secrets into the repo):
DATABASE_URL=

# Optional: override server port (default 3000)
PORT=3000
